{
  "name": "shorterlink",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "dev:web": "npm run dev --workspace=@shorterlink/web",
    "dev:api": "npm run dev --workspace=@shorterlink/api",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "prepare": "husky",
    "clean": "turbo run clean && rm -rf node_modules/.cache",
    "db:seed": "npx tsx prisma/seed.ts"
  },
  "lint-staged": {
    "apps/web/src/**/*.{ts,tsx}": [
      "npx --workspace=@shorterlink/web eslint --fix --no-warn-ignored"
    ],
    "apps/api/src/**/*.ts": [
      "npx --workspace=@shorterlink/api eslint --fix --no-warn-ignored"
    ]
  },
  "devDependencies": {
    "dotenv": "^17.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prisma": "^7.5.0",
    "turbo": "^2.5.4"
  }
}
